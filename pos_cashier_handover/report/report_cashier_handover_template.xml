<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_cashier_handover_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="session">
                <t t-set="data" t-value="session._get_handover_data()"/>
                <t t-call="web.external_layout">
                    <div class="page" style="direction: rtl; font-family: 'Arial', 'Tahoma', sans-serif;">

                        <!-- ====== HEADER ====== -->
                        <div style="text-align: center; border-bottom: 2px solid #333; padding-bottom: 12px; margin-bottom: 20px;">
                            <h2 style="margin: 0; font-size: 22px; font-weight: bold; letter-spacing: 1px;">
                                نموذج تسليم الخزينة
                            </h2>
                            <p style="margin: 4px 0 0; font-size: 13px; color: #555;">
                                Cash Handover Report
                            </p>
                        </div>

                        <!-- ====== SESSION INFO ====== -->
                        <table style="width: 100%; margin-bottom: 18px; border-collapse: collapse;">
                            <tr>
                                <td style="width: 50%; padding: 4px 0;">
                                    <strong>اسم الكاشير:</strong>
                                    <span style="margin-right: 8px;">
                                        <t t-esc="data['cashier_name']"/>
                                    </span>
                                </td>
                                <td style="width: 50%; padding: 4px 0; text-align: left;">
                                    <strong>الجلسة:</strong>
                                    <span style="margin-right: 8px;">
                                        <t t-esc="session.name"/>
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0;">
                                    <strong>تاريخ الإغلاق:</strong>
                                    <span style="margin-right: 8px;">
                                        <t t-esc="data['close_date'] and data['close_date'].strftime('%Y/%m/%d') or ''"/>
                                    </span>
                                </td>
                                <td style="padding: 4px 0; text-align: left;">
                                    <strong>وقت الإغلاق:</strong>
                                    <span style="margin-right: 8px;">
                                        <t t-esc="data['close_date'] and data['close_date'].strftime('%H:%M') or ''"/>
                                    </span>
                                </td>
                            </tr>
                        </table>

                        <!-- ====== FINANCIAL BREAKDOWN ====== -->
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                            <thead>
                                <tr style="background-color: #2c3e50; color: white;">
                                    <th style="padding: 10px 14px; text-align: right; font-size: 13px;">البيان</th>
                                    <th style="padding: 10px 14px; text-align: left; font-size: 13px; width: 200px;">المبلغ</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- إجمالي المبيعات -->
                                <tr style="background-color: #ecf0f1; font-weight: bold;">
                                    <td style="padding: 9px 14px; border-bottom: 1px solid #bdc3c7;">
                                        إجمالي المبيعات
                                    </td>
                                    <td style="padding: 9px 14px; border-bottom: 1px solid #bdc3c7; text-align: left;">
                                        <t t-esc="'{:,.2f}'.format(data['total_sales'])"/>
                                        <span style="margin-right: 4px; font-size: 11px; color: #666;">
                                            <t t-esc="session.currency_id.name"/>
                                        </span>
                                    </td>
                                </tr>

                                <!-- نقدي -->
                                <tr>
                                    <td style="padding: 8px 14px; border-bottom: 1px solid #ddd; padding-right: 28px;">
                                        نقدي (Cash)
                                    </td>
                                    <td style="padding: 8px 14px; border-bottom: 1px solid #ddd; text-align: left;">
                                        <t t-esc="'{:,.2f}'.format(data['cash_total'])"/>
                                        <span style="margin-right: 4px; font-size: 11px; color: #666;">
                                            <t t-esc="session.currency_id.name"/>
                                        </span>
                                    </td>
                                </tr>

                                <!-- فيزا / بطاقة -->
                                <tr style="background-color: #fafafa;">
                                    <td style="padding: 8px 14px; border-bottom: 1px solid #ddd; padding-right: 28px;">
                                        فيزا / بطاقة (Card)
                                    </td>
                                    <td style="padding: 8px 14px; border-bottom: 1px solid #ddd; text-align: left;">
                                        <t t-esc="'{:,.2f}'.format(data['card_total'])"/>
                                        <span style="margin-right: 4px; font-size: 11px; color: #666;">
                                            <t t-esc="session.currency_id.name"/>
                                        </span>
                                    </td>
                                </tr>

                                <!-- تحويلات -->
                                <tr>
                                    <td style="padding: 8px 14px; border-bottom: 1px solid #ddd; padding-right: 28px;">
                                        تحويلات بنكية (Bank Transfer)
                                    </td>
                                    <td style="padding: 8px 14px; border-bottom: 1px solid #ddd; text-align: left;">
                                        <t t-esc="'{:,.2f}'.format(data['transfer_total'])"/>
                                        <span style="margin-right: 4px; font-size: 11px; color: #666;">
                                            <t t-esc="session.currency_id.name"/>
                                        </span>
                                    </td>
                                </tr>

                                <!-- Cash In -->
                                <tr style="background-color: #fafafa;">
                                    <td style="padding: 8px 14px; border-bottom: 1px solid #ddd; padding-right: 28px;">
                                        إيداعات نقدية (Cash In)
                                    </td>
                                    <td style="padding: 8px 14px; border-bottom: 1px solid #ddd; text-align: left; color: #27ae60;">
                                        <t t-esc="'{:,.2f}'.format(data['cash_in'])"/>
                                        <span style="margin-right: 4px; font-size: 11px; color: #666;">
                                            <t t-esc="session.currency_id.name"/>
                                        </span>
                                    </td>
                                </tr>

                                <!-- Cash Out -->
                                <tr>
                                    <td style="padding: 8px 14px; border-bottom: 2px solid #aaa; padding-right: 28px;">
                                        سحوبات نقدية (Cash Out)
                                    </td>
                                    <td style="padding: 8px 14px; border-bottom: 2px solid #aaa; text-align: left; color: #e74c3c;">
                                        <t t-esc="'{:,.2f}'.format(data['cash_out'])"/>
                                        <span style="margin-right: 4px; font-size: 11px; color: #666;">
                                            <t t-esc="session.currency_id.name"/>
                                        </span>
                                    </td>
                                </tr>

                                <!-- المبلغ المسلم للحسابات -->
                                <tr style="background-color: #2c3e50; color: white; font-size: 15px; font-weight: bold;">
                                    <td style="padding: 12px 14px;">
                                        المبلغ المسلم للحسابات
                                    </td>
                                    <td style="padding: 12px 14px; text-align: left;">
                                        <t t-esc="'{:,.2f}'.format(data['delivered_to_accounts'])"/>
                                        <span style="margin-right: 6px; font-size: 12px;">
                                            <t t-esc="session.currency_id.name"/>
                                        </span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- ====== SIGNATURE SECTION ====== -->
                        <div style="margin-top: 40px;">
                            <table style="width: 100%; border-collapse: collapse;">
                                <tr>
                                    <!-- توقيع الكاشير -->
                                    <td style="width: 48%; text-align: center; vertical-align: top; padding: 10px;">
                                        <div style="border: 1px solid #aaa; border-radius: 6px; padding: 16px 10px; min-height: 80px;">
                                            <p style="margin: 0 0 8px; font-weight: bold; font-size: 13px;">
                                                توقيع الكاشير
                                            </p>
                                            <p style="margin: 0; font-size: 12px; color: #555;">
                                                <t t-esc="data['cashier_name']"/>
                                            </p>
                                            <div style="border-bottom: 1px dashed #999; margin-top: 40px;"></div>
                                        </div>
                                    </td>

                                    <td style="width: 4%;"></td>

                                    <!-- توقيع المستلم -->
                                    <td style="width: 48%; text-align: center; vertical-align: top; padding: 10px;">
                                        <div style="border: 1px solid #aaa; border-radius: 6px; padding: 16px 10px; min-height: 80px;">
                                            <p style="margin: 0 0 8px; font-weight: bold; font-size: 13px;">
                                                توقيع المستلم
                                            </p>
                                            <p style="margin: 0; font-size: 12px; color: #555;">
                                                &#160;
                                            </p>
                                            <div style="border-bottom: 1px dashed #999; margin-top: 40px;"></div>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- ====== FOOTER ====== -->
                        <div style="margin-top: 20px; text-align: center; font-size: 11px; color: #888; border-top: 1px solid #ddd; padding-top: 8px;">
                            تم إنشاء هذه الورقة تلقائياً عند إغلاق الجلسة — النظام لا يقبل أي تعديل بعد التوقيع
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
