<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!--
        نضيف زر "طباعة تسليم الخزينة" داخل نافذة إغلاق الجلسة
        بنستخدم t-inherit على template الـ ClosePosPopup
    -->
    <t t-inherit="point_of_sale.ClosePosPopup" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('notes-container')]" position="after">
            <div class="cashier-handover-section" style="padding: 12px 16px; border-top: 1px solid #dee2e6; background-color: #f8f9fa; margin-bottom: 8px;">
                <button
                    class="btn btn-primary w-100"
                    style="font-size: 15px; padding: 10px; background-color: #2c3e50; border-color: #2c3e50;"
                    t-on-click="printCashierHandover"
                >
                    <i class="fa fa-print me-2"/>
                    طباعة تسليم الخزينة
                </button>
            </div>
        </xpath>
    </t>

</templates>
