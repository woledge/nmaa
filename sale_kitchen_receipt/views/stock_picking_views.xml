<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- إضافة حقل اسم الطيار في فورم الدليفري (stock.picking)        -->
    <!-- ============================================================ -->
    <record id="view_picking_form_inherit_driver" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.driver.name</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="x_driver_name" string="اسم الطيار"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- إضافة عمود اسم الطيار في لست الدليفري                        -->
    <!-- ============================================================ -->
    <record id="view_picking_tree_inherit_driver" model="ir.ui.view">
        <field name="name">stock.picking.tree.inherit.driver.name</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="x_driver_name" string="الطيار" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
