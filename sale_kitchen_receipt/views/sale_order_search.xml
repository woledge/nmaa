<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- إضافة فلتر اسم الطيار في بحث أوامر البيع -->
    <record id="sale_order_search_inherit_kitchen" model="ir.ui.view">
        <field name="name">sale.order.search.inherit.kitchen.receipt</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="x_driver_name" string="اسم الطيار"/>
            </xpath>

            <xpath expr="//filter[@name='my_sale_orders_filter']" position="after">
                <separator/>
                <filter string="اسم الطيار" name="group_by_driver" context="{'group_by': 'x_driver_name'}"/>
            </xpath>

        </field>
    </record>

</odoo>