<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ===================== -->
        <!-- Category (Application) -->
        <!-- ===================== -->
        <record id="module_category_investment" model="ir.module.category">
            <field name="name">Investment</field>
            <field name="sequence">30</field>
        </record>

        <!-- ===================== -->
        <!-- Groups -->
        <!-- ===================== -->
        <record id="group_investment_user" model="res.groups">
            <field name="name">Investment User</field>
            <field name="category_id" ref="module_category_investment"/>
        </record>

        <record id="group_investment_manager" model="res.groups">
            <field name="name">Investment Manager</field>
            <field name="category_id" ref="module_category_investment"/>

            <!-- Manager يرث User -->
            <field name="implied_ids" eval="[(4, ref('group_investment_user'))]"/>

            <!-- اختياري: تخلي الادمن Manager -->
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- ===================== -->
        <!-- Record Rules (Multi Company) -->
        <!-- ===================== -->

        <record id="rule_investment_club_multi_company" model="ir.rule">
            <field name="name">Club Multi-Company</field>
            <field name="model_id" ref="model_investment_club"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

        <record id="rule_investment_project_multi_company" model="ir.rule">
            <field name="name">Project Multi-Company</field>
            <field name="model_id" ref="model_investment_project"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

        <record id="rule_investment_membership_multi_company" model="ir.rule">
            <field name="name">Membership Multi-Company</field>
            <field name="model_id" ref="model_investment_membership"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

    </data>
</odoo>