<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===== Access Rules - Loaded after models are installed ===== -->

    <!-- Project: Restrict creation to managers when setting is enabled -->
    <record id="investment_project_user_rule" model="ir.rule">
        <field name="name">Investment Project: User Read Only</field>
        <field name="model_id" ref="model_investment_project"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_investment_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="investment_project_manager_rule" model="ir.rule">
        <field name="name">Investment Project: Manager Full Access</field>
        <field name="model_id" ref="model_investment_project"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_investment_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Investment: User can view own investments, Manager can view all -->
    <record id="investment_subscription_user_rule" model="ir.rule">
        <field name="name">Investment Subscription: User View Own</field>
        <field name="model_id" ref="model_investment_subscription"/>
        <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_investment_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="investment_subscription_manager_rule" model="ir.rule">
        <field name="name">Investment Subscription: Manager Full Access</field>
        <field name="model_id" ref="model_investment_subscription"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_investment_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Membership: User can view own, Manager can view all -->
    <record id="investment_membership_user_rule" model="ir.rule">
        <field name="name">Investment Membership: User View Own</field>
        <field name="model_id" ref="model_investment_membership"/>
        <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_investment_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="investment_membership_manager_rule" model="ir.rule">
        <field name="name">Investment Membership: Manager Full Access</field>
        <field name="model_id" ref="model_investment_membership"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_investment_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Actual Return: User can view own, Manager can view all -->
    <record id="actual_return_user_rule" model="ir.rule">
        <field name="name">Actual Return: User View Own</field>
        <field name="model_id" ref="model_investment_actual_return"/>
        <field name="domain_force">[('subscription_id.partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_investment_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="actual_return_manager_rule" model="ir.rule">
        <field name="name">Actual Return: Manager Full Access</field>
        <field name="model_id" ref="model_investment_actual_return"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_investment_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>