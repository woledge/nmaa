<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- ===== Renewal Reminder Cron ===== -->
    <!-- Runs daily, checks memberships expiring within auto_renewal_days -->
    <record id="cron_membership_renewal_reminder" model="ir.cron">
        <field name="name">Investment Club: Send Renewal Reminders</field>
        <field name="model_id" ref="model_investment_membership"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_renewal_reminders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="priority">10</field>
    </record>

    <!-- ===== Payment Notification Cron ===== -->
    <!-- Runs daily, sends notifications for paid returns -->
    <record id="cron_return_payment_notification" model="ir.cron">
        <field name="name">Investment Club: Send Return Payment Notifications</field>
        <field name="model_id" ref="model_investment_actual_return"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_payment_notifications()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="priority">10</field>
    </record>

    <!-- ===== Auto Expire Memberships Cron ===== -->
    <!-- Runs daily, sets active memberships to expired if past expiry -->
    <record id="cron_expire_memberships" model="ir.cron">
        <field name="name">Investment Club: Auto Expire Memberships</field>
        <field name="model_id" ref="model_investment_membership"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_expire_memberships()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="priority">10</field>
    </record>

</odoo>
