<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_investment_subscription_list" model="ir.ui.view">
        <field name="name">investment.subscription.list</field>
        <field name="model">investment.subscription</field>
        <field name="arch" type="xml">
            <list decoration-success="grace_period_passed == True" decoration-muted="grace_period_passed == False">
                <field name="name" optional="hide"/>
                <field name="partner_id"/>
                <field name="project_id"/>
                <field name="return_calculation_type"/>
                <field name="investment_date"/>
                <field name="returns_start_date"/>
                <field name="grace_period_passed" invisible="1"/>
                <field name="months_until_returns_start"/>
                <field name="share_count"/>
                <field name="amount"/>
                <field name="expected_period_return"/>
                <field name="payment_state" widget="badge"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_investment_subscription_form" model="ir.ui.view">
        <field name="name">investment.subscription.form</field>
        <field name="model">investment.subscription</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_register_payment" type="object" 
                            string="Register Payment" 
                            invisible="state != 'draft'"
                            class="btn-primary"/>
                    
                    <button name="action_activate" type="object" 
                            string="Activate Investment" 
                            invisible="state != 'paid'"
                            class="btn-success"/>
                    
                    <button name="action_create_return" type="object" 
                            string="Create Return Payment" 
                            invisible="state != 'active'"
                            class="btn-secondary"/>
                    
                    <button name="action_close" type="object" 
                            string="Close" 
                            invisible="state != 'active'"
                            class="btn-secondary"/>
                    
                    <button name="action_cancel" type="object" 
                            string="Cancel" 
                            invisible="state in ('closed', 'cancelled')"
                            class="btn-danger"/>
                    
                    <field name="state" widget="statusbar"/>
                </header>
                
                <!-- ⚠️ تنبيه فترة السكون بالشهور -->
                <div class="alert alert-info" role="alert" invisible="grace_period_passed == True or state != 'active'">
                    <strong>Grace Period Active!</strong> 
                    Returns will start on <field name="returns_start_date"/> 
                    (<field name="months_until_returns_start"/> months and <field name="days_until_returns_start"/> days remaining)
                </div>
                
                <div class="alert alert-success" role="alert" invisible="grace_period_passed == False or state != 'active'">
                    <strong>Grace Period Passed!</strong> 
                    Return payments are now available.
                </div>
                
                <sheet>
                    <div class="oe_title">

                        <h3 class="text-muted">
                            Ref: <field name="name" readonly="1"/>
                        </h3>
                    </div>
                    
                    <group>
                        <group string="Investment Info">
                            <field name="membership_id"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="club_id" readonly="1"/>
                            <field name="project_id"/>
                            <field name="investment_date"/>
                        </group>
                        
                        <group string="Return Schedule (from Project)">
                            <field name="return_calculation_type" readonly="1"/>
                            <field name="grace_period_months" readonly="1"/>
                            <field name="returns_start_date" readonly="1"/>
                            <field name="grace_period_passed" readonly="1"/>
                            <field name="months_until_returns_start" readonly="1"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Financials">
                            <field name="share_count"/>
                            <field name="share_value"/>
                            <field name="amount"/>
                            <field name="return_percentage" readonly="1"/>
                            <field name="expected_period_return"/>
                        </group>
                        
                        <group string="Returns Summary">
                            <field name="capital_return_date" readonly="1"/>
                            <field name="total_actual_returns"/>
                            <field name="last_return_date"/>
                        </group>
                    </group>
                    
                    <group string="Payment">
                        <group>
                            <field name="payment_journal_id" invisible="state != 'draft'"/>
                            <field name="payment_id" readonly="1"/>
                            <field name="payment_state" widget="badge"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Actual Returns History">
                            <field name="actual_return_ids">
                                <list>
                                    <field name="period_name"/>
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                    <field name="expected_amount"/>
                                    <field name="actual_amount"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_investment_subscription_search" model="ir.ui.view">
        <field name="name">investment.subscription.search</field>
        <field name="model">investment.subscription</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="project_id"/>
                <field name="membership_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Paid" name="paid" domain="[('state', '=', 'paid')]"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Grace Period Passed" name="grace_passed" domain="[('grace_period_passed', '=', True)]"/>
                <filter string="In Grace Period" name="in_grace" domain="[('grace_period_passed', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="project" context="{'group_by': 'project_id'}"/>
                    <filter string="Return Type" name="return_type" context="{'group_by': 'return_calculation_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_investment_subscription" model="ir.actions.act_window">
        <field name="name">Investments</field>
        <field name="res_model">investment.subscription</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_investment_subscription_search"/>
    </record>

    <!-- Menu -->
</odoo>