<odoo>
    <record id="view_partner_form_inherit_code" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.code</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- نحط الحقل بعد الاسم -->
            <xpath expr="//field[@name='vat']" position="after">
<!--                <field name="code"/>-->
            </xpath>

        </field>
    </record>




    <record id="investor_code_account" model="ir.ui.view">
        <field name="name">Investor code</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <group>
                <field name="investor_code"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>