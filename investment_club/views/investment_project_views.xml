<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_investment_project_list" model="ir.ui.view">
        <field name="name">investment.project.list</field>
        <field name="model">investment.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="club_id"/>
                <field name="analytic_account_id"/>
                <field name="share_value"/>
                <field name="contract_start_date"/>
                <field name="contract_end_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_investment_project_form" model="ir.ui.view">
        <field name="name">investment.project.form</field>
        <field name="model">investment.project</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" type="object" string="Activate" invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_close" type="object" string="Close" invisible="state != 'active'" class="btn-danger"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="code" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="name" placeholder="Project Name"/>
                        </h2>
                    </div>
                    
                    <group>
                        <group>
                            <field name="club_id"/>
                            <field name="analytic_account_id"/>
                        </group>
                        <group>
                            <field name="share_value"/>
                            <field name="max_shares_per_investor"/>
                        </group>
                    </group>
                    
                    <!-- إعدادات العقد -->
                    <group string="Contract Settings">
                        <group>
                            <field name="contract_start_date"/>
                            <field name="contract_end_date"/>
                        </group>
                        <group>
                            <field name="grace_period_months"/>
                        </group>
                    </group>
                    
                    <!-- العائد الأول (مرة واحدة) -->
                    <group string="Return 1 (One-time)">
                        <group>
                            <field name="return_1_amount"/>
                            <field name="return_1_grace_months"/>
                        </group>
                        <group>
                            <field name="return_1_date"/>
                        </group>
                    </group>
                    
                    <!-- العائد الثاني (متكرر) -->
                    <group string="Return 2 (Recurring)">
                        <group>
                            <field name="return_2_amount"/>
                            <field name="return_2_percentage"/>
                            <field name="return_2_partner_share"/>
                            <field name="return_2_grace_months"/>
                        </group>
                        <group>
                            <field name="return_2_period_months"/>
                            <field name="return_2_duration_years"/>
                            <field name="return_2_first_date"/>
                            <field name="return_2_last_date"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_investment_project_search" model="ir.ui.view">
        <field name="name">investment.project.search</field>
        <field name="model">investment.project</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="club_id"/>
                <field name="analytic_account_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <group expand="0" string="Group By">
                    <filter string="Club" name="club" context="{'group_by': 'club_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_investment_project" model="ir.actions.act_window">
        <field name="name">Investment Projects</field>
        <field name="res_model">investment.project</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
