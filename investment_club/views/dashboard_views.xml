
<odoo>
    <!-- investment_club/views/dashboard_views.xml -->
<record id="investment_dashboard" model="ir.ui.view">
    <field name="name">Investment Dashboard</field>
    <field name="model">board.board</field>
    <field name="type">form</field>
    <field name="arch" type="xml">
        <form string="Investment Dashboard">
            <board style="2-1">
                <column>
                    <action string="Active Clubs" name="%(action_club_kanban)d"/>
                    <action string="Monthly Returns" name="%(action_return_graph)d"/>
                </column>
                <column>
                    <action string="Incomplete Contracts" name="%(action_incomplete_transactions)d"/>
                    <action string="Revenue Analysis" name="%(action_revenue_report)d"/>
                </column>
            </board>
        </form>
    </field>
</record>
</odoo>
