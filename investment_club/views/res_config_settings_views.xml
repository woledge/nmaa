<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="res_config_settings_view_form_investment" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.investment</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="90"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Investment Club" string="Investment Club" name="investment_club">

                    <block title="Membership Settings">
                        <setting string="Default Membership Product">
                            <field name="membership_product_id"/>
                        </setting>
                        <setting string="Default Subscription Product">
                            <field name="subscription_product_id"/>
                        </setting>
                        <setting string="Default Subscription Period">
                            <field name="subscription_period"/>
                        </setting>
                        <setting string="Auto Renewal Days Before">
                            <field name="auto_renewal_days"/>
                        </setting>
                    </block>

                    <block title="Financial Settings">
                        <setting string="Default Payment Journal">
                            <field name="payment_journal_id"/>
                        </setting>
                        <setting string="Returns Payment Journal">
                            <field name="return_payment_journal_id"/>
                        </setting>
                    </block>

                    <block title="Project Settings">
                        <setting string="Auto Activate Projects">
                            <field name="auto_activate_projects"/>
                        </setting>
                        <setting string="Default Grace Period (Months)">
                            <field name="grace_period_months"/>
                        </setting>
                    </block>

                    <block title="Security Settings">
                        <setting string="Restrict Project Creation to Managers">
                            <field name="restrict_project_creation"/>
                        </setting>
                        <setting string="Require Approval for Investments">
                            <field name="require_approval_for_investment"/>
                        </setting>
                    </block>

                    <block title="Notification Settings">
                        <setting string="Enable Renewal Notifications">
                            <field name="enable_renewal_notifications"/>
                        </setting>
                        <setting string="Enable Payment Notifications">
                            <field name="enable_payment_notifications"/>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>

    <!-- Configuration Menu -->


    <record id="action_investment_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'investment_club'}</field>
    </record>


</odoo>