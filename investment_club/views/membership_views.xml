<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_investment_membership_list" model="ir.ui.view">
        <field name="name">investment.membership.list</field>
        <field name="model">investment.membership</field>
        <field name="arch" type="xml">
            <list decoration-warning="renewal_status == 'due'" decoration-danger="renewal_status == 'overdue'">
                <field name="membership_number" optional="hide"/>
                <field name="partner_id"/>
                <field name="investor_code"/>
                <field name="club_id"/>
                <field name="initial_membership_fee"/>
                <field name="annual_subscription_fee"/>
                <field name="expiry_date"/>
                <field name="next_renewal_date"/>
                <field name="next_renewal_amount"/>
                <field name="renewal_status" widget="badge" 
                       decoration-success="renewal_status == 'paid'"
                       decoration-warning="renewal_status == 'due'"
                       decoration-danger="renewal_status == 'overdue'"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_investment_membership_form" model="ir.ui.view">
        <field name="name">investment.membership.form</field>
        <field name="model">investment.membership</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_initial_invoice" type="object" 
                            string="Create Initial Invoice" 
                            invisible="state != 'draft'"
                            class="btn-primary"/>
                    
                    <button name="action_confirm_payment" type="object" 
                            string="Confirm Payment &amp; Activate" 
                            invisible="state != 'initial_invoiced'"
                            class="btn-success"/>
                    
                    <button name="action_create_renewal_invoice" type="object" 
                            string="Create Renewal Invoice" 
                            invisible="renewal_status != 'due'"
                            class="btn-warning"/>
                    
                    <button name="action_create_investment" type="object" 
                            string="New Investment" 
                            invisible="state != 'active'"
                            class="btn-primary"/>
                    
                    <button name="action_cancel" type="object" 
                            string="Cancel" 
                            invisible="state in ('cancelled')"
                            class="btn-danger"/>
                    
                    <field name="state" widget="statusbar"/>
                </header>
                
                <div class="alert alert-warning" role="alert" invisible="renewal_status != 'due'">
                    <strong>Renewal Due!</strong> Amount: <field name="next_renewal_amount" widget="monetary"/>
                </div>
                <div class="alert alert-danger" role="alert" invisible="renewal_status != 'overdue'">
                    <strong>Renewal Overdue!</strong> Amount: <field name="next_renewal_amount" widget="monetary"/>
                </div>
                
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_open_invoice" class="oe_stat__button" icon="fa-file-text-o">
                            <field name="invoice_count" widget="statinfo" string="Invoice"/>
                        </button>
                    </div>
                    <!-- العنوان الرئيسي - Internal Ref -->
                    <div class="oe_title">
                        <h1>
                            <field name="membership_number" readonly="1"/>
                        </h1>
                        <!-- شيلنا h2 لأن مفيش حقل name في الموديل -->
                    </div>
                    
                    <group>
                        <group string="Customer &amp; Club">
                            <!-- كود العضوية فوق -->
                            <field name="partner_id"/>
                            <field name="investor_code"/>
                            <field name="club_id"/>
                        </group>
                        
                        <group string="Subscription Period">
                            <field name="subscription_period"/>
                            <field name="membership_date"/>
                            <field name="expiry_date"/>
                            <field name="auto_renew"/>
                        </group>
                    </group>
                    
                    <group string="Pricing">
                        <group string="Initial Membership (First Time)">
                            <field name="membership_product_id"/>
                            <field name="initial_membership_fee"/>
                        </group>
                        
                        <group string="Annual Subscription (Renewal)">
                            <field name="subscription_product_id"/>
                            <field name="annual_subscription_fee"/>
                        </group>
                    </group>
                    
                    <group string="Invoices &amp; Renewal">
                        <group>
                            <field name="initial_invoice_id"/>
                            <field name="current_invoice_id"/>
                            <field name="payment_state" widget="badge"/>
                        </group>
                        <group>
                            <field name="next_renewal_date"/>
                            <field name="next_renewal_amount"/>
                            <field name="renewal_status" widget="badge"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Renewal History">
                            <field name="renewal_ids">
                                <list>
                                    <field name="renewal_date"/>
                                    <field name="amount"/>
                                    <field name="period"/>
                                    <field name="old_expiry_date"/>
                                    <field name="new_expiry_date"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Investments">
                            <field name="investment_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="project_id"/>
                                    <field name="share_count"/>
                                    <field name="amount"/>
                                    <field name="payment_state" widget="badge"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
     
    <record id="view_investment_membership_calendar" model="ir.ui.view">
        <field name="name">investment.membership.calendar</field>
        <field name="model">investment.membership</field>
        <field name="arch" type="xml">
            <calendar
                string="Membership Renewals"
                date_start="next_renewal_date"
                date_stop="expiry_date"
                mode="month"
                color="renewal_status">
                <field name="partner_id"/>
                <field name="investor_code"/>
                <field name="club_id"/>
                <field name="next_renewal_amount"/>
                <field name="renewal_status"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_investment_membership_search" model="ir.ui.view">
        <field name="name">investment.membership.search</field>
        <field name="model">investment.membership</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="club_id"/>
                <field name="membership_number"/>
                <field name="investor_code"/>
            </search>
        </field>
    </record>

    <record id="action_investment_membership" model="ir.actions.act_window">
        <field name="name">Memberships</field>
        <field name="res_model">investment.membership</field>
        <field name="view_mode">list,form,calendar</field>
    </record>


</odoo>