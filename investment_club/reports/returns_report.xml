<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_monthly_returns_pdf" model="ir.actions.report">
        <field name="name">Monthly Returns PDF</field>
        <field name="model">investment.subscription</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">investment_club.monthly_returns</field>
        <field name="report_file">investment_club.monthly_returns</field>
        <field name="print_report_name">'Monthly Returns Report'</field>
    </record>

    <template id="monthly_returns">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page">
                    <h2>Monthly Returns Report</h2>
                    <p>Month: <span t-esc="month"/></p>
                    <p>Generated: <span t-esc="date"/></p>
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Project</th>
                                <th>Investors</th>
                                <th>Shares</th>
                                <th>Invested</th>
                                <th>Period Return</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="by_project.items()" t-as="item">
                                <td><span t-esc="item[0]"/></td>
                                <td><span t-esc="item[1]['investors']"/></td>
                                <td><span t-esc="item[1]['shares']"/></td>
                                <td><span t-esc="item[1]['invested']"/></td>
                                <td><span t-esc="item[1]['monthly_return']"/></td>
                            </tr>
                        </tbody>
                    </table>
                    <p><strong>Total Period Return:</strong> <span t-esc="total_monthly"/></p>
                    <p><strong>Total Annual Return:</strong> <span t-esc="total_annual"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>
