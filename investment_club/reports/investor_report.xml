<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_investor_summary_pdf" model="ir.actions.report">
        <field name="name">Investor Summary PDF</field>
        <field name="model">investment.membership</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">investment_club.investor_summary</field>
        <field name="report_file">investment_club.investor_summary</field>
        <field name="print_report_name">'Investor Summary'</field>
    </record>

    <template id="investor_summary">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page">
                    <h2>Investor Summary</h2>
                    <p>Generated: <span t-esc="date"/></p>
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Membership</th>
                                <th>Investor</th>
                                <th>Club</th>
                                <th>Investments</th>
                                <th>Total Invested</th>
                                <th>Period Return</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="investors" t-as="line">
                                <td><span t-esc="line['membership']"/></td>
                                <td><span t-esc="line['partner']"/></td>
                                <td><span t-esc="line['club']"/></td>
                                <td><span t-esc="line['investment_count']"/></td>
                                <td><span t-esc="line['total_invested']"/></td>
                                <td><span t-esc="line['monthly_return']"/></td>
                            </tr>
                        </tbody>
                    </table>
                    <p><strong>Total Membership Fees:</strong> <span t-esc="total_membership"/></p>
                    <p><strong>Total Invested:</strong> <span t-esc="total_investment"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>
