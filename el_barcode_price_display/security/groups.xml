<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_barcode_price" model="ir.module.category">
        <field name="name">Barcode Price Display</field>
        <field name="sequence">35</field>
    </record>

    <record id="group_barcode_price_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_barcode_price"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_barcode_price_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_barcode_price"/>
        <field name="implied_ids" eval="[(4, ref('group_barcode_price_user'))]"/>
    </record>
</odoo>
